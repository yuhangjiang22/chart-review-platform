.DS_Store

# Local tool/runtime state
.claude/

# Session-scoped rubric versioning: track the canonical rubric (criteria) + its
# promoted version snapshots under concur's .claude/skills, but keep per-session
# forks and run state ignored. Per-level re-include chain (git can't re-include a
# path whose parent dir is excluded, so un-ignore each level then re-ignore its
# other children).
!chart-review-platform-concur/.claude/
chart-review-platform-concur/.claude/*
!chart-review-platform-concur/.claude/skills/
chart-review-platform-concur/.claude/skills/*
!chart-review-platform-concur/.claude/skills/*/
chart-review-platform-concur/.claude/skills/*/*
!chart-review-platform-concur/.claude/skills/*/references/
!chart-review-platform-concur/.claude/skills/*/references/**
!chart-review-platform-concur/.claude/skills/*/versions/
!chart-review-platform-concur/.claude/skills/*/versions/**

# Upstream reference repo — vendored locally as a research mirror but
# not part of this project's history.
claude-agent-sdk-benchmark/

# Private patient samples — real-or-real-shaped clinical notes the
# methodologist drops in for local-only runs. Never commit.
chart-review-platform-v2/corpus/patients/patient_sample_*/
chart-review-platform-v2/corpus/patients/patient_private_*/
# Inbound staging dirs for raw note imports — kept at repo root for
# methodologist convenience but never part of the project's history.
/notes_sample/
/notes_private/
/bso-ad_notes_sample/

# Python
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/
build/

# Node/Vite
node_modules/
dist/
*.log

# Environment secrets
.env
.env.*
!.env.example

# Generated review artifacts
runs/
reviews/
# Test fixtures under reviews/ are NOT generated; commit them.
!chart-review-platform/lib/tests/fixtures/codify/reviews/
!chart-review-platform/lib/tests/fixtures/codify/reviews/**
cohorts/

# Runtime artifacts (eval / scripts output)
chart-review-platform/app/scripts/eval-parity-results.json
.claude/worktrees/
# Anchored: only the repo-root scratchpad workspace directory, NOT the
# React Workspace component folder (app/client/src/ui/Workspace/). On
# case-insensitive filesystems the unanchored pattern collides with
# the React folder and silently excludes ~30 component files.
/workspace/
