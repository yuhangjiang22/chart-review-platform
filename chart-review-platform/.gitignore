.venv/
build/
__pycache__/
*.egg-info/
*.pyc
.DS_Store

# Runtime data — all live under chart-review-platform/var/ since v0.7.1
# to keep the platform root tidy. Each subdirectory is regenerated per
# run / per patient, not source-of-truth, never committed.
#
# Contents:
#   var/runs/             Async batch runner outputs (manifests + drafts + audit)
#   var/reviews/          Per-patient×task live review state (the canonical
#                         document the reviewer commits; written by both agent
#                         and reviewer at runtime)
#   var/cohorts/          Cohort feedback artifacts produced by Role C
#   var/deployment-issues/ Per-guideline-sha JSONL logs from prod-deployment runs
#   var/methods/          Methods-section drafts — run-keyed bundles
#   var/notifications/    Per-reviewer notifications inbox
#   var/jobs/             Streaming-job transcripts
#   var/exports/          Reproducibility bundle exports — large
#   var/proposals/        Auto-critique rule proposals
#   var/calibration/      Calibration runs (ISO-timestamped subdirs per run)
var/

# On-disk bundle export tarballs (bundleId.tar.gz and friends).
*.tar.gz

# Draft tasks produced by Role A — committed selectively, not as a
# group; uncomment if you want to track drafts in this repo.
# tasks/drafts/

# Node deps + Vite build for the conversational app under app/
app/node_modules/
app/dist/
app/.env
app/.env.local
app/*.log

# Git worktrees for feature branches.
.worktrees/

# Project-local codex CLI state (CODEX_HOME). Only the checked-in
# config.toml is tracked; everything else (logs, sessions, auth,
# sqlite, models cache) is regenerated per-machine.
.codex/*
!.codex/config.toml
