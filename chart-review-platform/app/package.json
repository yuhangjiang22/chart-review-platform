{
  "name": "chart-review-mini",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimum chart-review tool with a Claude Agent SDK chat panel. Patient data is folders + files; the agent navigates one patient's chart at a time.",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/server.ts",
    "dev:client": "vite --port 5173 --config config/vite.config.ts",
    "build:client": "vite build --config config/vite.config.ts",
    "start": "tsx server/server.ts",
    "migrate-drafts": "tsx scripts/migrate-drafts.ts",
    "test": "vitest run --config config/vitest.config.ts",
    "test:watch": "vitest --config config/vitest.config.ts",
    "test:e2e": "./node_modules/.bin/playwright test --config config/playwright.config.ts --project=chromium",
    "test:e2e:ui": "./node_modules/.bin/playwright test --config config/playwright.config.ts --project=chromium --ui"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.28",
    "@anthropic-ai/sdk": "^0.91.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@types/pdfkit": "^0.17.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "lucide-react": "^1.14.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-use-websocket": "^4.13.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "ulid": "^3.0.2",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.47",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
