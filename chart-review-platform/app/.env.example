# Backend SDK config — routes the Claude Agent SDK through OpenRouter
# so we can use any OpenRouter-hosted model (e.g. deepseek/deepseek-v4-flash).
#
# Per OpenRouter's Claude Code integration guide:
#   https://openrouter.ai/docs/guides/coding-agents/claude-code-integration
# all three of these vars must be set; ANTHROPIC_API_KEY MUST be empty
# (not unset) to prevent the SDK from falling back to direct Anthropic auth.

ANTHROPIC_BASE_URL=https://openrouter.ai/api
ANTHROPIC_AUTH_TOKEN=sk-or-v1-replace-with-your-openrouter-key
ANTHROPIC_API_KEY=

# Model id passed to the SDK at session creation. OpenRouter routes by
# `provider/model-name`. Override per environment if you want to swap.
CHART_REVIEW_MODEL=deepseek/deepseek-v4-pro

# Server port (the React dev server is fixed at 5173).
PORT=3001

# Reviewer auth.
#   optional (default) — any reviewer_id is accepted; identity is
#                        captured on every action + audit entry.
#   required           — reviewer_id must be in REVIEWERS below.
REVIEWER_AUTH=optional

# Comma-separated allowlist of reviewer ids (used only when
# REVIEWER_AUTH=required). Allowed identifier chars: a-z 0-9 _ . @ -
REVIEWERS=alice,bob,carol
