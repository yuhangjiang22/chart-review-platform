# Copy to .env and fill in. .env is gitignored.
#
# v2 is independent: nothing in this repo reads from a parent
# chart-review-platform/ install. CHART_REVIEW_PLATFORM_ROOT below
# pins the runtime path to this directory; without it, the legacy
# ../chart-review-platform fallback in some helpers would resolve
# outside the repo.

# ──────────────────────────────────────────────────────────────────────
# Runtime paths
# ──────────────────────────────────────────────────────────────────────

# Absolute path to THIS checkout. Set after cloning so corpus + var
# paths resolve correctly.
CHART_REVIEW_PLATFORM_ROOT=/absolute/path/to/chart-review-platform

# ──────────────────────────────────────────────────────────────────────
# Agent provider
# ──────────────────────────────────────────────────────────────────────

# claude | codex. Per-run override available via API but not in UI.
AGENT_PROVIDER=claude

# Force LLM-as-judge to Claude regardless of run provider — codex's
# JSON output omits the sentinel the judge parser expects.
CHART_REVIEW_JUDGE_PROVIDER=claude

# Absolute path to codex binary (only needed if AGENT_PROVIDER=codex
# and the binary isn't on the dev server's PATH).
# CHART_REVIEW_CODEX_BIN=/path/to/codex

# ──────────────────────────────────────────────────────────────────────
# Models
# ──────────────────────────────────────────────────────────────────────

# Default model for chart-review, copilot, etc.
CHART_REVIEW_MODEL=anthropic/claude-haiku-4.5

# (Optional) override the LLM-as-judge model.
# CHART_REVIEW_JUDGE_MODEL=anthropic/claude-sonnet-4.6

# (Optional) HIPAA-safe model for patients flagged phi: true.
# CHART_REVIEW_PHI_MODEL=

# ──────────────────────────────────────────────────────────────────────
# Claude / Anthropic
# ──────────────────────────────────────────────────────────────────────

# Pick ONE of these depending on your routing:
# (a) Anthropic direct:
#   ANTHROPIC_API_KEY=sk-ant-…
#   (omit ANTHROPIC_BASE_URL)
# (b) OpenRouter:
#   ANTHROPIC_AUTH_TOKEN=sk-or-…
#   ANTHROPIC_BASE_URL=https://openrouter.ai/api
# (c) Bedrock / Vertex AI: see Anthropic SDK docs

ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=

# Used by some legacy paths when ANTHROPIC_* is unset.
OPENROUTER_API_KEY=

# ──────────────────────────────────────────────────────────────────────
# Codex / Azure OpenAI
# ──────────────────────────────────────────────────────────────────────

# Azure OpenAI Foundry — needed when .codex/config.toml's active
# model_provider is "azure".
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=

# ──────────────────────────────────────────────────────────────────────
# Auth
# ──────────────────────────────────────────────────────────────────────

# optional | required. "optional" lets anonymous browse but methodologist
# actions still require a session token.
REVIEWER_AUTH=optional

# Comma-separated list of allowed reviewer IDs. Empty = anyone can log in.
REVIEWERS=

# Comma-separated list of methodologists (= can start runs, lock, deploy).
# Empty = every logged-in user counts as a methodologist (dev default).
METHODOLOGISTS=
