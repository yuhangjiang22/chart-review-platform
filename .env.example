# Copy to .env and fill in. .env is gitignored — never commit secrets.
#
# chart-review-platform-concur: deepagents provider, Azure OpenAI or vLLM,
# one phenotype task (cancer-diagnosis), three phases only.

# ──────────────────────────────────────────────────────────────────────
# Runtime paths
# ──────────────────────────────────────────────────────────────────────

# Absolute path to THIS checkout. Required: corpus + var paths resolve
# from here.
CHART_REVIEW_PLATFORM_ROOT=/absolute/path/to/chart-review-platform-concur

# ──────────────────────────────────────────────────────────────────────
# Agent provider
# ──────────────────────────────────────────────────────────────────────

# deepagents is the only supported provider in this fork.
AGENT_PROVIDER=deepagents

# Sidecar connects to the stdio MCP server as a subprocess.
MCP_TRANSPORT=subprocess

# Absolute path to the Python ≥3.11 venv created under python/.venv:
#   cd python && uv venv .venv --python 3.11 && uv pip install -e .
DEEPAGENTS_PYTHON=/absolute/path/to/python/.venv/bin/python

# ──────────────────────────────────────────────────────────────────────
# LLM backend (pick azure or vllm)
# ──────────────────────────────────────────────────────────────────────

# azure | vllm
DEEPAGENTS_LLM_BACKEND=azure

# ── Azure OpenAI (tested, gpt-4o) ─────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── vLLM (local model server; e.g. Qwen3-32B) ────────────────────────
# Read the live endpoint from nlp/vllm_endpoint.txt after the server starts
# (it changes every job). VLLM_API_KEY can be any non-empty string.
VLLM_BASE_URL=
VLLM_MODEL=
VLLM_API_KEY=

# Route PHI-bearing agents to a specific model regardless of the default.
# On HPC this pins clinical-note extraction to the local vLLM model so PHI
# never leaves the BAA boundary. Leave empty to use the backend default.
CHART_REVIEW_PHI_MODEL=

# ──────────────────────────────────────────────────────────────────────
# Auth
# ──────────────────────────────────────────────────────────────────────

# optional | required. "optional" lets anonymous browse; methodologist
# actions (start run, validate) still work without login in dev mode.
REVIEWER_AUTH=optional

# Comma-separated list of allowed reviewer IDs. Empty = anyone can log in.
REVIEWERS=

# Comma-separated list of methodologists. Empty = every logged-in user
# counts as a methodologist (dev default).
METHODOLOGISTS=

# LLM-as-judge (optional JUDGE phase). The judge runs on the deepagents
# provider, so this must be a python/models.json KEY (not an anthropic/* id) —
# model-config defaults resolve to an anthropic model deepagents can't serve.
# Use a CAPABLE instruction-follower: the judge emits strict-JSON in
# <JUDGE_ANALYSIS> sentinels, and weaker models (gpt-4o, small qwen) tend to
# break the schema. Verified working: claude-sonnet via OpenRouter — add a
# models.json entry {backend:vllm, base_url_env:VLLM_BASE_URL, model:
# "anthropic/claude-sonnet-4.6", api_key_env:VLLM_API_KEY} and set
# VLLM_BASE_URL=https://openrouter.ai/api/v1 + VLLM_API_KEY=<OpenRouter key>.
CHART_REVIEW_JUDGE_MODEL=claude-sonnet
