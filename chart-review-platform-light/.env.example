# Copy to .env and fill in. .env is gitignored — never commit secrets.
#
# chart-review-platform-light: deepagents provider, Azure OpenAI or vLLM,
# one phenotype task (lung-cancer-phenotype-light), three phases only.

# ──────────────────────────────────────────────────────────────────────
# Runtime paths
# ──────────────────────────────────────────────────────────────────────

# Absolute path to THIS checkout. Required: corpus + var paths resolve
# from here.
CHART_REVIEW_PLATFORM_ROOT=/absolute/path/to/chart-review-platform-light

# ──────────────────────────────────────────────────────────────────────
# Agent provider
# ──────────────────────────────────────────────────────────────────────

# deepagents is the only supported provider in this fork.
AGENT_PROVIDER=deepagents

# Sidecar connects to the stdio MCP server as a subprocess.
MCP_TRANSPORT=subprocess

# Absolute path to the Python ≥3.11 venv created under python/.venv:
#   cd python && uv venv .venv --python 3.11 && uv pip install -e .
DEEPAGENTS_PYTHON=/absolute/path/to/python/.venv/bin/python

# ──────────────────────────────────────────────────────────────────────
# LLM backend (pick azure or vllm)
# ──────────────────────────────────────────────────────────────────────

# azure | vllm
DEEPAGENTS_LLM_BACKEND=azure

# ── Azure OpenAI (tested, gpt-4o) ─────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── vLLM (unavailable in this environment; here for reference) ─────────
VLLM_BASE_URL=
VLLM_MODEL=
VLLM_API_KEY=

# ──────────────────────────────────────────────────────────────────────
# Auth
# ──────────────────────────────────────────────────────────────────────

# optional | required. "optional" lets anonymous browse; methodologist
# actions (start run, validate) still work without login in dev mode.
REVIEWER_AUTH=optional

# Comma-separated list of allowed reviewer IDs. Empty = anyone can log in.
REVIEWERS=

# Comma-separated list of methodologists. Empty = every logged-in user
# counts as a methodologist (dev default).
METHODOLOGISTS=
